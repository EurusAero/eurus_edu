[Unit]
 Description=Запускает api сервер для взаимодействия клиента и дрона
 After=network-online.target multi-user.target
 Wants=network-online.target

[Service]
 User=orangepi
 WorkingDirectory=/home/orangepi/ros2_ws/
 ExecStart=/home/orangepi/ros2_ws/src/eurus_edu/scripts/start_edu_api_server.sh
 Restart=always
 RestartSec=1

[Install]
 WantedBy=multi-user.target
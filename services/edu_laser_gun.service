[Unit]
 Description=Запускает управление лазерной пушкой
 After=network-online.target multi-user.target
 Wants=network-online.target

[Service]
 User=root
 WorkingDirectory=/home/orangepi/ros2_ws/
 ExecStart=/home/orangepi/ros2_ws/src/eurus_edu/scripts/start_edu_laser_gun.sh
 TimeoutStopSec=2
 Restart=always
 RestartSec=1

[Install]
 WantedBy=multi-user.target